# Expo는 EXPO_PUBLIC_ 접두사 env를 앱 번들에 노출함 (개발 프로토타입용)
# ⚠️ 키가 번들에 노출되므로 프로덕션 전 Supabase Edge Function으로 이동할 것
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-

# Supabase — 설정하면 데이터가 클라우드(kv_store, RLS)에 저장됨. 비우면 로컬(AsyncStorage)로 동작.
# Supabase 대시보드 > Project Settings > API 에서 복사. anon 키는 공개키(RLS로 보호).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

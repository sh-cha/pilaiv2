{
  "expo": {
    "name": "Pilai",
    "slug": "pilai",
    "scheme": "pilai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shcha.pilai"
    },
    "android": {
      "package": "com.shcha.pilai",
      "adaptiveIcon": {
        "backgroundColor": "#2F4636",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser"
    ]
  }
}
